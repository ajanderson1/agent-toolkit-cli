#!/usr/bin/env bash
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
# shellcheck source=lib/common.sh
. "$LIB_DIR/common.sh"

usage() {
  cat <<'EOF'
agent-toolkit — manage harness-agnostic assets across Claude Code, Codex, OpenCode, and Pi.

Usage:
  agent-toolkit <command> [options]

Commands that manage symlinks (filesystem, zero-dep bash):
  link <user|project> <harness>    Project assets into the harness's config dir
                                   (idempotent — safe to re-run).
  unlink <user|project> <harness>  Remove only symlinks pointing into this repo.
  list <user|project>              List symlinks in user-/project-scope dirs that
                                   point into this repo.

Commands that operate on metadata (Python via uv):
  check                            Validate every asset's frontmatter and detect
                                   AGENTS.md auto-region drift. Used by lefthook.
  fix                              Regenerate AGENTS.md auto-regions from the
                                   current asset inventory.
  doctor                           Quick environment sanity check (schema, git,
                                   gh, submodules). Reports only — never gates.
  new <kind> <slug>                Scaffold a new asset with valid v1alpha1
                                   frontmatter. Kinds: skill, agent, command,
                                   hook, mcp, plugin.

Common options:
  --repo-root DIR    Operate on this repo (defaults to current directory).
  --dry-run          link/unlink: show what would change without doing it.
  --quiet, -q        Suppress header/summary chrome (also via AGENT_TOOLKIT_QUIET=1).
  --exit-code        check: exit non-zero on any error (CI gate).

Examples:
  agent-toolkit link user claude            # set up Claude Code on a fresh machine
  agent-toolkit link user claude --dry-run  # preview what's drifted from the source of truth
  agent-toolkit check --exit-code           # validate (used by lefthook pre-commit)
  agent-toolkit new skill my-skill          # scaffold a new skill

Documentation: docs/agent-toolkit/cli.md
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  link|unlink|list)
    # shellcheck source=lib/link.sh
    . "$LIB_DIR/${cmd}.sh"
    "${cmd}_main" "$@"
    ;;
  check|fix|doctor|new)
    exec uv run agent-toolkit "$cmd" "$@"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "unknown subcommand: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
