#!/usr/bin/env bash
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
# shellcheck source=lib/common.sh
. "$LIB_DIR/common.sh"

usage() {
  cat <<'EOF'
agent-toolkit — manage harness-agnostic assets across Claude Code, Codex, OpenCode, and Pi.

Usage:
  agent-toolkit <command> [options]

Commands that manage symlinks (filesystem, zero-dep bash):
  link <user|project> <harness> [<kind>:<slug>] [--all] [-y]
                                   Project assets per the allow-list. Bare form
                                   reads the file. <kind>:<slug> adds one slug
                                   then projects. --all snapshots every
                                   compatible asset (prompts unless -y).
  unlink <user|project> <harness> (--all | <kind>:<slug>)
                                   Bare form errors with a hint. --all clears
                                   every symlink for the scope+harness (file
                                   preserved). <kind>:<slug> removes one slug
                                   from the file and prunes its symlink.
  list [<kind>] [<harness>]        Inventory + install state. Filter by kind
                                   and/or harness; both are positional and
                                   disambiguated by name.
  diff <user|project> <harness>    Preview what 'link' would change (alias for
                                   'link --dry-run').

Commands that operate on metadata (Python via uv):
  check                            Validate every asset's frontmatter and detect
                                   AGENTS.md auto-region drift. Used by lefthook.
  fix                              Regenerate AGENTS.md auto-regions from the
                                   current asset inventory.
  doctor [<slug>]                  Five-group health check (environment,
                                   symlink-integrity, conventions,
                                   submodule-health, frontmatter); pass a slug
                                   for per-resource diagnosis.
  inventory [<kind>|<slug>]        Browse the asset library (filterable by
                                   --harness / --origin / --lifecycle / --format).
  ingest [<url|name|file>]         Run the IDENTIFY/RESEARCH/STAGE pipeline for
                                   third-party assets; --finalize/--abort/--slug
                                   manage the staging dir.
  new <kind> <slug>                Scaffold a new asset with valid v1alpha1
                                   frontmatter. Kinds: skill, agent, command,
                                   hook, mcp, plugin.

Common options:
  --repo-root DIR    Operate on this repo (defaults to current directory).
  --dry-run          link/unlink: show what would change without doing it.
  --quiet, -q        Suppress header/summary chrome (also via AGENT_TOOLKIT_QUIET=1).
  --exit-code        check/doctor: exit non-zero on any error (CI gate).

Examples:
  agent-toolkit link user claude --all       # snapshot everything compatible, project
  agent-toolkit link user claude skill:figma # add one skill, project
  agent-toolkit list                         # full inventory + install state
  agent-toolkit list skill claude            # filter to claude-compatible skills
  agent-toolkit unlink user claude --all     # clear all claude symlinks for user
  agent-toolkit check --exit-code            # validate (used by lefthook pre-commit)
  agent-toolkit doctor                       # five-group repo health check
  agent-toolkit inventory --harness pi       # what's available for the Pi harness
  agent-toolkit new skill my-skill           # scaffold a new skill

Documentation: docs/agent-toolkit/cli.md
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  link|unlink|list|diff)
    # Detect "conventions" target (sibling of <harness>)
    # Args layout: link <user|project> <harness-or-conventions> [flags]
    third_arg=""
    if [ "$#" -ge 2 ]; then third_arg="$2"; fi
    if [ "$third_arg" = "conventions" ]; then
      # shellcheck source=lib/conventions.sh
      . "$LIB_DIR/conventions.sh"
      "conventions_${cmd}_main" "$@"
    else
      # shellcheck source=lib/link.sh
      . "$LIB_DIR/${cmd}.sh"
      "${cmd}_main" "$@"
    fi
    ;;
  check|fix|doctor|new|inventory|ingest)
    exec uv run agent-toolkit "$cmd" "$@"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "unknown subcommand: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
